{
  "name": "subgate-nano",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:all": "turbo run dev --filter=@subgate/api --filter=@subgate/web --filter=@subgate/worker --filter=@subgate/sidecar --filter=@subgate/bot-telegram",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @subgate/db generate",
    "db:migrate": "pnpm --filter @subgate/db migrate",
    "db:seed": "pnpm --filter @subgate/db seed",
    "demo:x402:local": "pnpm --filter @subgate/api demo:x402",
    "smoke:api": "pnpm --filter @subgate/api smoke",
    "smoke:bot-telegram": "pnpm --filter @subgate/bot-telegram smoke",
    "smoke:worker": "pnpm --filter @subgate/worker smoke",
    "smoke:sidecar": "pnpm --filter @subgate/sidecar smoke",
    "smoke:local": "node tools/smoke-local.mjs"
  },
  "devDependencies": {
    "turbo": "^2.0.12",
    "typescript": "^5.5.4"
  }
}
